{
  "name": "codex-token-dashboard",
  "version": "1.0.1",
  "description": "A local dashboard for visualizing Codex token usage from ~/.codex logs.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "codex-token-dashboard": "bin/codex-token-dashboard.js"
  },
  "files": [
    "bin",
    "dist",
    "server",
    "src",
    "index.html",
    "vite.config.js",
    "eslint.config.js",
    "README.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jack-Tsue/codex-token-dashboard.git"
  },
  "bugs": {
    "url": "https://github.com/Jack-Tsue/codex-token-dashboard/issues"
  },
  "homepage": "https://github.com/Jack-Tsue/codex-token-dashboard#readme",
  "keywords": [
    "codex",
    "tokens",
    "dashboard",
    "usage",
    "openai"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently \"node server/index.js\" \"vite --host 127.0.0.1\"",
    "build": "vite build",
    "start": "node bin/codex-token-dashboard.js",
    "preview": "npm run build && node bin/codex-token-dashboard.js --no-open",
    "lint": "eslint .",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "vite": "^7.2.4",
    "typescript": "^5.9.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "recharts": "^3.5.1",
    "lucide-react": "^0.561.0",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0"
  }
}
